Actual Last 12 Months = 
VAR MaxDate =
    CALCULATE(
        MAX('public view_fact_bike_rentals'[dteday]),
        REMOVEFILTERS('public view_fact_bike_rentals')
    )
VAR StartDate =
    EDATE(MaxDate, -12)
RETURN
    CALCULATE(
        SUM('public view_fact_bike_rentals'[rentals]),
        FILTER(
            ALL('public dim_date'),
            'public dim_date'[dteday] > StartDate &&
            'public dim_date'[dteday] <= MaxDate
        )
    )
